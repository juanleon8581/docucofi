# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL="your-supabase-url"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"

# Local PDF generation: path to Chrome/Chromium executable
# macOS default: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Linux example: /usr/bin/google-chrome-stable
# Not needed in Vercel/Lambda (uses @sparticuz/chromium-min automatically)
CHROME_EXECUTABLE_PATH="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"

# Serverless PDF generation: URL to the chromium brotli binary (used in Vercel/Lambda)
# Defaults to the sparticuz/chromium GitHub release for the pinned version.
# Override to use a self-hosted mirror for faster cold starts.
CHROMIUM_BINARY_URL="https://github.com/Sparticuz/chromium/releases/download/v143.0.0/chromium-v143.0.0-pack.tar"
