# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL="your-supabase-url"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"

# Local PDF generation: path to Chrome/Chromium executable
# macOS default: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Linux example: /usr/bin/google-chrome-stable
# Not needed in Vercel/Lambda (uses @sparticuz/chromium automatically)
CHROME_EXECUTABLE_PATH="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
